# Copy this file to ".env" and fill in your Supabase project credentials.
# Find these in your Supabase dashboard → Project Settings → API.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional DEV-ONLY flag: when "true" (and running `npm run dev`), the login/
# register screens are skipped and the app loads as a fake admin for UI testing.
# RLS still applies, so real data reads/writes won't work. Leave unset/false normally.
# VITE_DEV_BYPASS_AUTH=true
